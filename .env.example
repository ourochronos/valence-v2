# Valence Engine Configuration

# Server Configuration
VALENCE_HOST=0.0.0.0
VALENCE_PORT=8421

# Database Configuration
# Leave empty or comment out to use in-memory storage (MemoryStore)
# For PostgreSQL, use format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://valence:valence_dev_password@localhost:5433/valence

# PostgreSQL Password (used by docker-compose)
POSTGRES_PASSWORD=valence_dev_password

# Logging Configuration
# Valid levels: trace, debug, info, warn, error
RUST_LOG=info

# Embedding Configuration (optional)
# EMBEDDING_DIMENSIONS=128

# Maintenance Cycle Configuration (optional)
# DECAY_FACTOR=0.95
# MIN_WEIGHT=0.01
# EVICT_THRESHOLD=0.1
