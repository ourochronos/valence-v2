# Valence Engine Configuration

# PostgreSQL Configuration
# Comment out or remove to use in-memory storage
DATABASE_URL=postgresql://valence:valence_dev_password@localhost:5432/valence
POSTGRES_PASSWORD=valence_dev_password

# Server Configuration
VALENCE_HOST=0.0.0.0
VALENCE_PORT=8421
VALENCE_MODE=http  # Options: http, mcp, both

# Logging
RUST_LOG=info  # Options: trace, debug, info, warn, error
